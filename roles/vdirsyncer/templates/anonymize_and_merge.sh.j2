#!/usr/bin/env bash
set -euo pipefail

DATASHARE_DIR="/var/lib/vdirsyncer/local_datashare"
EXCHANGE_DIR="/var/lib/vdirsyncer/local_exchange"
ICLOUD_PRIVAT_DIR="/var/lib/vdirsyncer/local_icloud_privat"
WORK_DIR="/var/lib/vdirsyncer/availability_work"
PRIVATE_DIR="/var/lib/vdirsyncer/availability_private"
MAP_FILE="/var/lib/vdirsyncer/uid_map.json"

mkdir -p "$WORK_DIR" "$PRIVATE_DIR"

python3 - "$DATASHARE_DIR" "$EXCHANGE_DIR" "$ICLOUD_PRIVAT_DIR" "$WORK_DIR" "$PRIVATE_DIR" "$MAP_FILE" <<'PY'
import hashlib, json, pathlib, re, sys

src_ds = pathlib.Path(sys.argv[1])
src_ex = pathlib.Path(sys.argv[2])
src_ip = pathlib.Path(sys.argv[3])
work_dir = pathlib.Path(sys.argv[4])
private_dir = pathlib.Path(sys.argv[5])
map_file = pathlib.Path(sys.argv[6])

STRIP = re.compile(
    r"^(SUMMARY|DESCRIPTION|LOCATION|ATTENDEE|ORGANIZER)"
    r"[:;].*(?:\r?\n[ \t].*)*\r?\n?",
    re.MULTILINE,
)
UID_RE = re.compile(r"^UID[:;](.*?)$", re.MULTILINE)

if map_file.exists():
    with open(map_file, "r", encoding="utf-8") as f:
        uid_map = json.load(f)
else:
    uid_map = {}

def process_source(prefix, src, out_dir):
    expected = set()
    current_keys = set()
    for ics in src.rglob("*.ics"):
        content = ics.read_bytes().decode("utf-8")
        content = content.replace("\r\n", "\n").replace("\n", "\r\n")

        uid_match = UID_RE.search(content)
        original_uid = uid_match.group(1).strip() if uid_match else ics.stem
        mapping_key = f"{prefix}_{original_uid}"
        current_keys.add(mapping_key)

        if mapping_key not in uid_map:
            new_uid = hashlib.sha256(f"{original_uid}_{prefix}".encode()).hexdigest()[:32]
            uid_map[mapping_key] = new_uid
        modified_uid = uid_map[mapping_key]

        if uid_match:
            content = UID_RE.sub(f"UID:{modified_uid}", content, count=1)
        else:
            content = re.sub(
                r"(BEGIN:VEVENT\r?\n)",
                f"\\1UID:{modified_uid}\r\n",
                content,
                count=1,
            )

        name = f"{prefix}_{modified_uid}.ics"
        expected.add(name)

        content = STRIP.sub("", content)
        content = re.sub(
            r"(BEGIN:VEVENT\r?\n)",
            "\\1SUMMARY:Arbeitstermin\r\n",
            content,
        )
        content = re.sub(r"\r?\n\r?\n+", "\r\n", content)
        (out_dir / name).write_bytes(content.encode("utf-8"))

    return expected, current_keys

work_expected = set()
private_expected = set()
all_current_keys = set()

exp, keys = process_source("ds", src_ds, work_dir)
work_expected.update(exp)
all_current_keys.update(keys)

exp, keys = process_source("ex", src_ex, work_dir)
work_expected.update(exp)
all_current_keys.update(keys)

exp, keys = process_source("ip", src_ip, private_dir)
private_expected.update(exp)
all_current_keys.update(keys)

# Remove stale files from work_dir
for old in work_dir.glob("*.ics"):
    if old.name not in work_expected:
        old.unlink()

# Remove stale files from private_dir
for old in private_dir.glob("*.ics"):
    if old.name not in private_expected:
        old.unlink()

for orphaned_key in list(uid_map.keys()):
    if orphaned_key not in all_current_keys:
        del uid_map[orphaned_key]

with open(map_file, "w", encoding="utf-8") as f:
    json.dump(uid_map, f, indent=2)
PY
